# =============================================================================
# Cursor Hyderabad Meetup - Credit Claim Portal
# Copy this file to .env.local and fill in real values.
# =============================================================================

# ---- Event branding (safe to expose) ----------------------------------------
NEXT_PUBLIC_EVENT_NAME="Cursor Hyderabad Meetup"
NEXT_PUBLIC_EVENT_DATE="May 24"
NEXT_PUBLIC_EVENT_HOST="Fahad"
NEXT_PUBLIC_EVENT_ORGANIZER="Cursor Hyderabad, India"
NEXT_PUBLIC_SUPPORT_EMAIL="cursor.hyderabad@example.com"

# ---- Supabase (Postgres) ----------------------------------------------------
# Project Settings > API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_PUBLIC_ANON_KEY"
# SERVICE ROLE key — server-only, NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"

# ---- Resend (transactional email) -------------------------------------------
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxx"
# Must be a verified sender on a domain you've added to Resend.
RESEND_FROM_EMAIL="Cursor Hyderabad <credits@yourdomain.dev>"
# Optional reply-to address (defaults to RESEND_FROM_EMAIL).
RESEND_REPLY_TO="cursor.hyderabad@example.com"

# ---- Public URL (used to build absolute asset URLs in emails) --------------
# Set this in Vercel to your canonical production URL (e.g. https://creds.cursorhyderabad.in).
# If unset, falls back to VERCEL_URL (auto-populated by Vercel on each deploy),
# then to http://localhost:3000 (dev only — email images won't load in real inboxes).
NEXT_PUBLIC_APP_URL="https://your-deployment.vercel.app"

# ---- Admin access -----------------------------------------------------------
# Plain password used to log into /admin. Pick something strong.
ADMIN_PASSWORD="change-me-to-a-strong-passphrase"
# Random string used to sign the admin session cookie (any 32+ char string).
ADMIN_SESSION_SECRET="generate-a-long-random-string-32-chars-or-more"

# ---- Rate limiting ----------------------------------------------------------
# Per-IP attempts per window (claim endpoint).
RATE_LIMIT_MAX="5"
# Window in seconds.
RATE_LIMIT_WINDOW="60"
