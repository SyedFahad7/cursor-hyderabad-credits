# =============================================================================
# Cursor Hyderabad Meetup - Credit Claim Portal
# Copy this file to .env.local and fill in real values.
# =============================================================================

# ---- Event branding (safe to expose) ----------------------------------------
NEXT_PUBLIC_EVENT_NAME="Cursor Hyderabad Meetup"
NEXT_PUBLIC_EVENT_DATE="May 24"
NEXT_PUBLIC_EVENT_HOST="Fahad"
NEXT_PUBLIC_EVENT_ORGANIZER="Cursor Hyderabad, India"
NEXT_PUBLIC_SUPPORT_EMAIL="cursor.hyderabad@example.com"

# ---- Supabase (Postgres) ----------------------------------------------------
# Project Settings > API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_PUBLIC_ANON_KEY"
# SERVICE ROLE key — server-only, NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"

# ---- Email transport (configure ONE of the two below) ----------------------
# We support two transports. If both are set, Gmail wins.
#
# OPTION A: Gmail SMTP via Nodemailer  (FREE, 500 emails/day, no domain)
#   1. Visit https://myaccount.google.com/security and enable 2-Step Verification.
#   2. Visit https://myaccount.google.com/apppasswords and create a new
#      "App password" (16 characters, no spaces).
#   3. Paste your Gmail address and the app password below.
GMAIL_USER=""
GMAIL_APP_PASSWORD=""

# OPTION B: Resend (better deliverability, REQUIRES verified domain)
#   - Add a domain at https://resend.com/domains and verify SPF/DKIM/DMARC
#     records in your DNS provider, then change RESEND_FROM_EMAIL to use it.
RESEND_API_KEY=""

# Sender display info (used by both transports). Format: 'Name <email@host>'.
# When using Gmail, the email address part is replaced with GMAIL_USER, but
# the display name is preserved so the recipient still sees "Cursor Hyderabad".
RESEND_FROM_EMAIL="Cursor Hyderabad <credits@yourdomain.dev>"
# Optional reply-to address (defaults to the sender).
RESEND_REPLY_TO="cursor.hyderabad@example.com"

# ---- Public URL (used to build absolute claim-page links) ------------------
# Set this in Vercel to your canonical production URL (e.g. https://creds.cursorhyderabad.in).
# If unset, falls back to VERCEL_URL (auto-populated by Vercel on each deploy).
NEXT_PUBLIC_APP_URL="https://your-deployment.vercel.app"

# ---- Admin access -----------------------------------------------------------
# Plain password used to log into /admin. Pick something strong.
ADMIN_PASSWORD="change-me-to-a-strong-passphrase"
# Random string used to sign the admin session cookie (any 32+ char string).
ADMIN_SESSION_SECRET="generate-a-long-random-string-32-chars-or-more"

# ---- Rate limiting ----------------------------------------------------------
# Per-IP attempts per window (claim endpoint).
RATE_LIMIT_MAX="5"
# Window in seconds.
RATE_LIMIT_WINDOW="60"
